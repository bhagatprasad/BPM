<?xml version="1.0" encoding="utf-8" ?>
<log4net>
	<appender name="RollingFileAppender" type="log4net.Appender.RollingFileAppender">
		<!-- Dynamic file path from property -->
		<file type="log4net.Util.PatternString" value="%property{LogFileName}" />

		<!-- Append to existing file -->
		<appendToFile value="true" />

		<!-- Date rolling strategy - creates new file daily -->
		<rollingStyle value="Date" />

		<!-- Date pattern for daily rolling -->
		<datePattern value="yyyy-MM-dd" />

		<!-- Keep current log file name static (without date suffix) -->
		<staticLogFileName value="true" />

		<!-- Keep logs for 30 days -->
		<maxSizeRollBackups value="30" />

		<!-- Layout configuration -->
		<layout type="log4net.Layout.PatternLayout">
			<conversionPattern value="%date{yyyy-MM-dd HH:mm:ss.fff} [%thread] %-5level %logger{1} - %message%newline%exception" />
		</layout>
	</appender>

	<!-- Root logger configuration -->
	<root>
		<level value="ALL" />
		<appender-ref ref="RollingFileAppender" />
	</root>
</log4net>